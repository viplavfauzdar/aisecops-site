---
const { title, description, href } = Astro.props;
---
<a href={href} class="group block rounded-2xl border border-white/10 bg-white/5 hover:bg-white/7 transition p-6">
  <div class="flex items-start justify-between gap-4">
    <div>
      <div class="font-semibold text-white group-hover:text-cyan-100">{title}</div>
      <p class="mt-2 text-sm text-slate-300">{description}</p>
    </div>
    <span class="text-slate-400 group-hover:text-cyan-200">→</span>
  </div>
</a>
