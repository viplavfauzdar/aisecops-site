---
const { title, description, href } = Astro.props;
---
<a href={href} class="group block rounded-md border border-black/10 bg-white hover:bg-[#fdfbf8] transition p-6 no-underline">
  <div class="flex items-start justify-between gap-4">
    <div>
      <div class="font-semibold text-ink group-hover:text-[#c94f1e]">{title}</div>
      <p class="mt-2 text-sm text-[#6b6460] leading-relaxed">{description}</p>
    </div>
    <span class="text-[#8a837f] group-hover:text-[#c94f1e]">→</span>
  </div>
</a>
