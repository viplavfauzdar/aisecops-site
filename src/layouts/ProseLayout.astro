---
import BaseLayout from "./BaseLayout.astro";
const { title, description } = Astro.props;
---
<BaseLayout title={title} description={description}>
  <article class="prose-page">
    <slot />
  </article>
</BaseLayout>

<style is:global>
  .prose-page {
    max-width: 760px;
    margin: 0 auto;
    padding: 3rem 0 4rem;
  }

  .prose-page h1 {
    font-family: var(--serif);
    font-size: clamp(2.4rem, 5vw, 4rem);
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 0 0 1.2rem;
  }

  .prose-page h2 {
    font-family: var(--serif);
    font-size: 1.9rem;
    font-weight: 400;
    line-height: 1.2;
    margin: 2.5rem 0 0.75rem;
    padding-top: 2rem;
    border-top: 1px solid var(--rule);
  }

  .prose-page h3 {
    font-size: 1.05rem;
    font-weight: 600;
    margin: 1.5rem 0 0.5rem;
  }

  .prose-page p,
  .prose-page li {
    color: #2a2a2a;
    font-size: 1rem;
    line-height: 1.7;
  }

  .prose-page a {
    color: var(--accent);
    text-decoration: none;
  }

  .prose-page a:hover { text-decoration: underline; }

  .prose-page pre {
    background: #1a1f2e;
    color: #7ecfb3;
    border-radius: 8px;
    padding: 1rem 1.2rem;
    overflow-x: auto;
  }

  .prose-page hr { border-color: var(--rule); }
  .prose-page strong { color: var(--ink); }
</style>
