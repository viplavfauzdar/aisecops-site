---
import "../styles/global.css";
import Seo from "../components/Seo.astro";
import Analytics from "../components/Analytics.astro";
import MermaidSupport from "../components/MermaidSupport.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const {
  title = "AISecOps — Security for Agentic AI Systems",
  description = "AISecOps is the emerging discipline for securing agentic AI in production. Runtime policy enforcement, least-privilege tool access, audit logging, and containment — for AI that acts.",
  jsonLd = null
} = Astro.props;

const orgJsonLd = jsonLd ?? ({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "AISecOps",
  "url": "https://aisecops.net",
  "logo": "https://aisecops.net/logo.svg",
  "description": "The emerging discipline for securing agentic AI systems at runtime.",
  "sameAs": [
    "https://github.com/viplavfauzdar/aisecops-lab",
    "https://medium.com/@viplav.fauzdar"
  ]
});
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <Seo title={title} description={description} jsonLd={orgJsonLd} />
    <Analytics />
  </head>
  <body>
    <Header />
    <main class="mx-auto max-w-[960px] px-4 md:px-8">
      <slot />
    </main>
    <Footer />
    <MermaidSupport />
  </body>
</html>
