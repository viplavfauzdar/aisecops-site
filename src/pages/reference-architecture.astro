---
import ProseLayout from "../layouts/ProseLayout.astro";
import ArchitectureContent from "../content/architecture.md";

const title = "AISecOps Reference Architecture";
const description = "AISecOps v0.2 runtime control plane architecture: context controls, capability gates, execution governance, local enforcement, and structured auditability.";
---
<ProseLayout title={title} description={description}>
  <div class="not-prose diagram-wrap">
    <img src="/architecture.svg" alt="AISecOps Reference Architecture Diagram" class="w-full h-auto" />
    <div class="diagram-note">
      AISecOps v0.2 runtime control plane architecture with local enforcement,
      capability-gated execution, explicit plan/evaluate/execute separation,
      and structured audit logging.
    </div>
  </div>
  <ArchitectureContent />
</ProseLayout>

<style>
  .diagram-wrap {
    margin-top: 2rem;
    border-radius: 8px;
    border: 1px solid var(--rule);
    background: #fff;
    padding: 1.25rem;
  }

  .diagram-note {
    margin-top: 0.6rem;
    font-size: 0.75rem;
    color: var(--muted);
  }
</style>
