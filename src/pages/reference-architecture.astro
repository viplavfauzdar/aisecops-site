---
import ProseLayout from "../layouts/ProseLayout.astro";
import ArchitectureContent from "../content/architecture.md";

const title = "AISecOps Reference Architecture";
const description = "Layered model: Context, Capability, Execution, Observability.";
---
<ProseLayout title={title} description={description}>
  <div class="not-prose diagram-wrap">
    <img src="/architecture.svg" alt="AISecOps Reference Architecture Diagram" class="w-full h-auto" />
    <div class="diagram-note">SVG diagram shipped with the site — replace anytime.</div>
  </div>
  <ArchitectureContent />
</ProseLayout>

<style>
  .diagram-wrap {
    margin-top: 2rem;
    border-radius: 8px;
    border: 1px solid var(--rule);
    background: #fff;
    padding: 1.25rem;
  }

  .diagram-note {
    margin-top: 0.6rem;
    font-size: 0.75rem;
    color: var(--muted);
  }
</style>
