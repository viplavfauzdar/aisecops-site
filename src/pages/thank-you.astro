---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Thanks — AISecOps" description="Thanks for subscribing.">
  <section class="thanks-page">
    <h1>You’re in.</h1>
    <p>Thanks — you’ll get updates and the whitepaper link as it evolves.</p>
    <div class="actions">
      <a href="/whitepaper" class="btn-primary">Back to Whitepaper</a>
      <a href="/blog" class="btn-secondary">Read the Blog</a>
    </div>
  </section>
</BaseLayout>

<style>
  .thanks-page {
    padding: 5rem 0 6rem;
    max-width: 680px;
    margin: 0 auto;
    text-align: center;
  }

  .thanks-page h1 {
    font-family: var(--serif);
    font-size: clamp(2.1rem, 4vw, 3rem);
    font-weight: 400;
    margin: 0;
  }

  .thanks-page p { margin-top: 0.8rem; color: var(--muted); }

  .actions {
    margin-top: 1.6rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.7rem;
  }

  .btn-primary,
  .btn-secondary {
    display: inline-block;
    padding: 0.7rem 1.2rem;
    border-radius: 3px;
    font-family: var(--mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-decoration: none;
  }

  .btn-primary { background: var(--accent); color: #fff; }
  .btn-primary:hover { background: #a83d12; }
  .btn-secondary { background: #fff; border: 1px solid var(--rule); color: var(--ink); }
  .btn-secondary:hover { border-color: var(--ink); }
</style>
