---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Thanks — AISecOps" description="Thanks for subscribing.">
  <section class="py-20 max-w-2xl mx-auto text-center">
    <h1 class="text-4xl md:text-5xl font-serif font-normal text-ink">You’re in.</h1>
    <p class="mt-4 text-[#6b6460]">Thanks — you’ll get updates and the whitepaper link as it evolves.</p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href="/whitepaper" class="px-5 py-3 rounded-[3px] bg-[#c94f1e] hover:bg-[#a83d12] border border-[#c94f1e] text-white font-mono text-[0.75rem] tracking-[0.04em] uppercase">Back to Whitepaper</a>
      <a href="/blog" class="px-5 py-3 rounded-[3px] bg-white hover:bg-[#fdfbf8] border border-black/15 text-ink font-mono text-[0.75rem] tracking-[0.04em] uppercase">Read the Blog</a>
    </div>
  </section>
</BaseLayout>
