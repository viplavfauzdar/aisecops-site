---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Thanks — AISecOps" description="Thanks for subscribing.">
  <section class="py-20 max-w-2xl mx-auto text-center">
    <h1 class="text-4xl font-semibold text-white">You’re in.</h1>
    <p class="mt-4 text-slate-300">Thanks — you’ll get updates and the whitepaper link as it evolves.</p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href="/whitepaper" class="px-5 py-3 rounded-2xl bg-cyan-400/15 hover:bg-cyan-400/20 border border-cyan-300/20 text-cyan-100">Back to Whitepaper</a>
      <a href="/blog" class="px-5 py-3 rounded-2xl bg-white/10 hover:bg-white/15 border border-white/10 text-white">Read the Blog</a>
    </div>
  </section>
</BaseLayout>
