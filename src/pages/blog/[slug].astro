---
import ProseLayout from "../../layouts/ProseLayout.astro";
import { getCollection } from "astro:content";
export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.filter(p => !p.data.draft).map(p => ({ params: { slug: p.slug }, props: { post: p } }));
}
const { post } = Astro.props;
const { Content } = await post.render();
---
<ProseLayout title={post.data.title} description={post.data.description}>
  <header class="not-prose mb-10">
    <div class="text-sm text-[#8a837f]">{post.data.pubDate.toLocaleDateString("en-US", { year:"numeric", month:"long", day:"2-digit" })}</div>
    <h1 class="mt-2 text-3xl md:text-4xl font-normal font-serif text-ink">{post.data.title}</h1>
    <p class="mt-3 text-[#6b6460]">{post.data.description}</p>
  </header>
  <Content />
</ProseLayout>
