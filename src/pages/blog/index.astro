---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
const posts = (await getCollection("blog")).filter(p => !p.data.draft).sort((a,b)=>b.data.pubDate.valueOf()-a.data.pubDate.valueOf());
---
<BaseLayout title="AISecOps Blog" description="Patterns and playbooks for securing agentic AI systems.">
  <section class="py-12 max-w-3xl mx-auto">
    <h1 class="text-3xl font-semibold text-ink">Blog</h1>
    <p class="mt-3 text-[#6b6460]">Practical notes: threat modeling, runtime policy enforcement, and auditability.</p>
    <div class="mt-8 grid gap-4">
      {posts.map((post) => (
        <a href={`/blog/${post.slug}`} class="block rounded-md border border-black/10 bg-white hover:bg-[#fdfbf8] p-6 transition">
          <div class="text-xs text-[#8a837f]">{post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "2-digit" })}</div>
          <div class="mt-1 text-lg font-semibold text-ink">{post.data.title}</div>
          <div class="mt-2 text-sm text-[#6b6460]">{post.data.description}</div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
