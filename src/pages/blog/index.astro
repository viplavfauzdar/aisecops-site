---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
const posts = (await getCollection("blog")).filter(p => !p.data.draft).sort((a,b)=>b.data.pubDate.valueOf()-a.data.pubDate.valueOf());
---
<BaseLayout title="AISecOps Blog" description="Patterns and playbooks for securing agentic AI systems.">
  <section class="blog-index">
    <h1>Blog</h1>
    <p class="intro">Practical notes: threat modeling, runtime policy enforcement, and auditability.</p>
    <div class="post-grid">
      {posts.map((post) => (
        <a href={`/blog/${post.slug}`} class="post-card">
          <div class="date">{post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "2-digit" })}</div>
          <div class="title">{post.data.title}</div>
          <div class="desc">{post.data.description}</div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .blog-index {
    max-width: 760px;
    margin: 0 auto;
    padding: 3rem 0 4rem;
  }

  .blog-index h1 {
    font-family: var(--serif);
    font-size: 2.6rem;
    font-weight: 400;
    line-height: 1.15;
    margin: 0;
  }

  .intro {
    margin-top: 0.7rem;
    color: var(--muted);
  }

  .post-grid {
    margin-top: 2rem;
    display: grid;
    gap: 0.8rem;
  }

  .post-card {
    display: block;
    border: 1px solid var(--rule);
    border-radius: 6px;
    background: #fff;
    padding: 1.1rem 1.2rem;
    text-decoration: none;
    color: inherit;
  }

  .post-card:hover { background: #fdfbf8; }
  .date { font-size: 0.75rem; color: var(--muted); }
  .title { margin-top: 0.15rem; font-family: var(--serif); font-size: 1.25rem; line-height: 1.2; }
  .desc { margin-top: 0.35rem; font-size: 0.92rem; color: var(--muted); }
</style>
