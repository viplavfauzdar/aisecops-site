---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Page Not Found — AISecOps" description="The page you requested does not exist.">
  <section class="py-20 max-w-2xl mx-auto text-center">
    <h1 class="text-4xl md:text-5xl font-serif font-normal text-ink">404</h1>
    <p class="mt-4 text-[#6b6460]">That page doesn’t exist.</p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href="/" class="px-5 py-3 rounded-[3px] bg-[#c94f1e] hover:bg-[#a83d12] border border-[#c94f1e] text-white font-mono text-[0.75rem] tracking-[0.04em] uppercase">Home</a>
      <a href="/definition" class="px-5 py-3 rounded-[3px] bg-white hover:bg-[#fdfbf8] border border-black/15 text-ink font-mono text-[0.75rem] tracking-[0.04em] uppercase">Definition</a>
      <a href="/blog" class="px-5 py-3 rounded-[3px] bg-white hover:bg-[#fdfbf8] border border-black/15 text-ink font-mono text-[0.75rem] tracking-[0.04em] uppercase">Blog</a>
    </div>
  </section>
</BaseLayout>
