---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Page Not Found — AISecOps" description="The page you requested does not exist.">
  <section class="error-page">
    <h1>404</h1>
    <p>That page doesn’t exist.</p>
    <div class="actions">
      <a href="/" class="btn-primary">Home</a>
      <a href="/definition" class="btn-secondary">Definition</a>
      <a href="/blog" class="btn-secondary">Blog</a>
    </div>
  </section>
</BaseLayout>

<style>
  .error-page {
    padding: 5rem 0 6rem;
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }

  .error-page h1 {
    font-family: var(--serif);
    font-size: 3rem;
    font-weight: 400;
    margin: 0;
  }

  .error-page p { margin-top: 0.8rem; color: var(--muted); }

  .actions {
    margin-top: 1.6rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.7rem;
  }

  .btn-primary,
  .btn-secondary {
    display: inline-block;
    padding: 0.7rem 1.2rem;
    border-radius: 3px;
    font-family: var(--mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-decoration: none;
  }

  .btn-primary { background: var(--accent); color: #fff; }
  .btn-primary:hover { background: #a83d12; }
  .btn-secondary { background: #fff; border: 1px solid var(--rule); color: var(--ink); }
  .btn-secondary:hover { border-color: var(--ink); }
</style>
