---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Page Not Found — AISecOps" description="The page you requested does not exist.">
  <section class="py-20 max-w-2xl mx-auto text-center">
    <h1 class="text-4xl font-semibold text-white">404</h1>
    <p class="mt-4 text-slate-300">That page doesn’t exist.</p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href="/" class="px-5 py-3 rounded-2xl bg-cyan-400/15 hover:bg-cyan-400/20 border border-cyan-300/20 text-cyan-100">Home</a>
      <a href="/definition" class="px-5 py-3 rounded-2xl bg-white/10 hover:bg-white/15 border border-white/10 text-white">Definition</a>
      <a href="/blog" class="px-5 py-3 rounded-2xl bg-white/10 hover:bg-white/15 border border-white/10 text-white">Blog</a>
    </div>
  </section>
</BaseLayout>
