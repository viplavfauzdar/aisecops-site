---
import ProseLayout from "../layouts/ProseLayout.astro";
import { getCollection } from "astro:content";
const title = "AISecOps Whitepaper";
const description = "Download the AISecOps framework whitepaper and subscribe for updates.";
const whitepapers = await getCollection("whitepapers");
const whitepaper = whitepapers.find((entry) => entry.id.startsWith("aisecops-v0.1"));
if (!whitepaper) {
  throw new Error("Missing whitepaper entry: src/content/whitepapers/aisecops-v0.1.md");
}
const { Content } = await whitepaper.render();
---
<ProseLayout title={title} description={description}>
  <Content />
  <p class="mt-8">Download the current draft PDF (placeholder included). Replace the file later without changing links.</p>
  <div class="not-prose actions">
    <a href="/whitepaper/download" class="btn-primary">Download PDF</a>
    <a href="/reference-architecture" class="btn-secondary">See Architecture</a>
  </div>
  <h2 class="mt-10">Get notified</h2>
  <form name="whitepaper-early-access" method="POST" data-netlify="true" action="/thank-you" class="not-prose signup-form">
    <input type="hidden" name="form-name" value="whitepaper-early-access" />
    <div>
      <label class="form-label">Email</label>
      <input name="email" type="email" required placeholder="you@company.com"
        class="form-input" />
    </div>
    <div>
      <label class="form-label">Company (optional)</label>
      <input name="company" type="text" placeholder="Company"
        class="form-input" />
    </div>
    <button type="submit" class="btn-submit">
      Request early access
    </button>
    <div class="form-note">No spam. Unsubscribe anytime.</div>
  </form>
</ProseLayout>

<style>
  .actions {
    margin-top: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .btn-primary,
  .btn-secondary {
    display: inline-block;
    font-family: var(--mono);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    text-decoration: none;
    padding: 0.7rem 1.2rem;
    border-radius: 3px;
  }

  .btn-primary {
    background: var(--ink);
    color: #fff;
  }

  .btn-primary:hover { background: var(--accent); }

  .btn-secondary {
    border: 1px solid var(--rule);
    background: #fff;
    color: var(--ink);
  }

  .btn-secondary:hover { border-color: var(--ink); }

  .signup-form {
    margin-top: 1rem;
    display: grid;
    gap: 0.8rem;
    max-width: 620px;
    border: 1px solid var(--rule);
    border-radius: 8px;
    background: #fff;
    padding: 1.25rem;
  }

  .form-label {
    display: block;
    margin-bottom: 0.25rem;
    font-size: 0.85rem;
    color: var(--ink);
  }

  .form-input {
    width: 100%;
    border: 1px solid var(--rule);
    border-radius: 4px;
    padding: 0.65rem 0.8rem;
    font-size: 0.9rem;
    color: var(--ink);
    background: #fff;
  }

  .form-input:focus {
    outline: none;
    border-color: var(--accent);
  }

  .btn-submit {
    width: 100%;
    border: none;
    border-radius: 4px;
    background: var(--accent);
    color: #fff;
    padding: 0.7rem 1rem;
    font-family: var(--mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    cursor: pointer;
  }

  .btn-submit:hover { background: #a83d12; }
  .form-note { font-size: 0.75rem; color: var(--muted); }
</style>
