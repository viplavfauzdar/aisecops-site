---
import ProseLayout from "../layouts/ProseLayout.astro";
import { getCollection } from "astro:content";
const title = "AISecOps Whitepaper";
const description = "Download the AISecOps framework whitepaper and subscribe for updates.";
const whitepapers = await getCollection("whitepapers");
const whitepaper = whitepapers.find((entry) => entry.id.startsWith("aisecops-v0.1"));
if (!whitepaper) {
  throw new Error("Missing whitepaper entry: src/content/whitepapers/aisecops-v0.1.md");
}
const { Content } = await whitepaper.render();
---
<ProseLayout title={title} description={description}>
  <Content />
  <p class="mt-8">Download the current draft PDF (placeholder included). Replace the file later without changing links.</p>
  <div class="not-prose mt-6 flex flex-wrap gap-3">
    <a href="/whitepaper/download" class="px-5 py-3 rounded-[3px] bg-[#c94f1e] hover:bg-[#a83d12] border border-[#c94f1e] text-white">Download PDF</a>
    <a href="/reference-architecture" class="px-5 py-3 rounded-[3px] bg-white hover:bg-[#fdfbf8] border border-black/15 text-ink">See Architecture</a>
  </div>
  <h2 class="mt-10">Get notified</h2>
  <form name="whitepaper-early-access" method="POST" data-netlify="true" action="/thank-you" class="not-prose mt-4 space-y-3 rounded-3xl border border-black/15 bg-white p-6 max-w-xl">
    <input type="hidden" name="form-name" value="whitepaper-early-access" />
    <div>
      <label class="block text-sm text-ink mb-1">Email</label>
      <input name="email" type="email" required placeholder="you@company.com"
        class="w-full px-3 py-2 rounded-xl bg-white border border-black/15 text-ink placeholder:text-[#8a837f] focus:outline-none focus:border-[#c94f1e]" />
    </div>
    <div>
      <label class="block text-sm text-ink mb-1">Company (optional)</label>
      <input name="company" type="text" placeholder="Company"
        class="w-full px-3 py-2 rounded-xl bg-white border border-black/15 text-ink placeholder:text-[#8a837f] focus:outline-none focus:border-[#c94f1e]" />
    </div>
    <button type="submit" class="w-full px-4 py-2.5 rounded-xl bg-[#c94f1e] hover:bg-[#a83d12] border border-[#c94f1e] text-white">
      Request early access
    </button>
    <div class="text-xs text-[#8a837f]">No spam. Unsubscribe anytime.</div>
  </form>
</ProseLayout>
