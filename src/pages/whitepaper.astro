---
import ProseLayout from "../layouts/ProseLayout.astro";
import { getCollection } from "astro:content";
const title = "AISecOps Whitepaper";
const description = "Download the AISecOps framework whitepaper and subscribe for updates.";
const whitepapers = await getCollection("whitepapers");
const whitepaper = whitepapers.find((entry) => entry.id.startsWith("aisecops-v0.1"));
if (!whitepaper) {
  throw new Error("Missing whitepaper entry: src/content/whitepapers/aisecops-v0.1.md");
}
const { Content } = await whitepaper.render();
---
<ProseLayout title={title} description={description}>
  <Content />
  <p class="mt-8">Download the current draft PDF (placeholder included). Replace the file later without changing links.</p>
  <div class="not-prose mt-6 flex flex-wrap gap-3">
    <a href="/whitepaper/download" class="px-5 py-3 rounded-2xl bg-cyan-400/15 hover:bg-cyan-400/20 border border-cyan-300/20 text-cyan-100">Download PDF</a>
    <a href="/reference-architecture" class="px-5 py-3 rounded-2xl bg-white/10 hover:bg-white/15 border border-white/10 text-white">See Architecture</a>
  </div>
  <h2 class="mt-10">Get notified</h2>
  <form name="whitepaper-early-access" method="POST" data-netlify="true" action="/thank-you" class="not-prose mt-4 space-y-3 rounded-3xl border border-white/10 bg-white/5 p-6 max-w-xl">
    <input type="hidden" name="form-name" value="whitepaper-early-access" />
    <div>
      <label class="block text-sm text-slate-200 mb-1">Email</label>
      <input name="email" type="email" required placeholder="you@company.com"
        class="w-full px-3 py-2 rounded-xl bg-white/5 border border-white/10 text-white placeholder:text-slate-500 focus:outline-none focus:ring-2 focus:ring-cyan-300/30" />
    </div>
    <div>
      <label class="block text-sm text-slate-200 mb-1">Company (optional)</label>
      <input name="company" type="text" placeholder="Company"
        class="w-full px-3 py-2 rounded-xl bg-white/5 border border-white/10 text-white placeholder:text-slate-500 focus:outline-none focus:ring-2 focus:ring-cyan-300/30" />
    </div>
    <button type="submit" class="w-full px-4 py-2.5 rounded-xl bg-cyan-400/15 hover:bg-cyan-400/20 border border-cyan-300/20 text-cyan-100">
      Request early access
    </button>
    <div class="text-xs text-slate-400">No spam. Unsubscribe anytime.</div>
  </form>
</ProseLayout>
