---
import ProseLayout from "../layouts/ProseLayout.astro";
const title = "AISecOps Open Source";
const description = "Open-source building blocks for AISecOps.";
---
<ProseLayout title={title} description={description}>
<h1>Open Source</h1>
<p>Catalog building blocks, examples, and reusable patterns.</p>
<p class="not-prose mt-6">
  <a class="inline-flex items-center px-4 py-2 rounded-[3px] bg-[#c94f1e] hover:bg-[#a83d12] border border-[#c94f1e] text-white font-mono text-[0.75rem] tracking-[0.04em] uppercase no-underline" href="https://github.com/viplavfauzdar/aisecops-lab">View GitHub</a>
</p>

</ProseLayout>
