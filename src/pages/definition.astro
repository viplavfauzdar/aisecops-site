---
import ProseLayout from "../layouts/ProseLayout.astro";
import { getEntry } from "astro:content";

const definition = await getEntry("pages", "definition");
if (!definition) {
  throw new Error("Missing page entry: src/content/pages/definition.md");
}
const { Content } = await definition.render();
---
<ProseLayout title={definition.data.title} description={definition.data.description}>
  <Content />
</ProseLayout>
